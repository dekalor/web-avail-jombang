# .env.example — copy to .env

NODE_ENV=local
PORT=3000
SITE_URL=http://localhost:3000
ADMIN_HMR_PORT=24678
CLIENT_HMR_PORT=24679
BODY_LIMIT=20mb

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Security
SESSION_SECRET=change-session-secret
SESSION_MAX_AGE_MS=86400000
CORS_ORIGINS=http://localhost:3000 #Comma separated string
ORDER_CREATE_RATE_LIMIT_WINDOW_MS=600000
ORDER_CREATE_RATE_LIMIT_MAX=5
CHECKOUT_CHALLENGE_MIN_SUBMIT_MS=3000
CHECKOUT_CHALLENGE_TTL_MS=600000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=avail_db
DB_DIALECT=mysql

# Shipping
FREE_SHIPPING_MIN=700000
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id
RAJAONGKIR_API_KEY=change-to-api-key
RAJAONGKIR_CACHE_DAYS=30
ORIGIN_DISTRICT_ID=3852
DEFAULT_WEIGHT=1000

#Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRODUCTS_FOLDER=avail/products
CLOUDINARY_PRODUCT_DETAILS_FOLDER=avail/product-details
CLOUDINARY_ORDERS_FOLDER=avail/orders

#MailConfig
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Avail Jombang <yourgmail@gmail.com>"
ORDER_NOTIFICATION_EMAIL=owner@example.com
