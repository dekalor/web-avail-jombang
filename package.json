{
  "name": "avail-jombang-store",
  "version": "1.0.0",
  "private": true,
  "description": "Avail Jombang Store (Vite + Vue SFC + Express MVC + MySQL)",
  "workspaces": [
    "client",
    "admin",
    "server"
  ],
  "scripts": {
    "dev": "nodemon server/index.js",
    "build": "node server/scripts/generateSitemap.js && npm run build -w client && npm run build -w admin",
    "start": "node server/index.js",
    "migrateup": "npx sequelize-cli db:migrate",
    "migratedownto": "npx sequelize-cli db:migrate:undo:all",
    "migratedownname": "npx sequelize-cli db:migrate:undo",
    "seed": "npx sequelize-cli db:seed"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.2.0"
  }
}
